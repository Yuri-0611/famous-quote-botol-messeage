# ========= 本番（HTTPS の独自ドメイン例）=========
# 必ず https:// で始めてください（OGP・canonical 用）
NEXT_PUBLIC_SITE_URL=https://example.com

# ========= 運営倉庫 /warehouse（必ず強力な値に）=========
# 8 文字以上。/warehouse/login で入力し、Cookie でセッション維持。
WAREHOUSE_PASSWORD=

# ========= Turso（本番と開発で別 DB を推奨）=========
# 本番用 libSQL URL / トークン（Cloudflare の Secrets にも同じキー名で設定）
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# ローカル開発では .env.local に「開発用 DB」の値だけを入れる運用にしてください。

# ========= OpenAI（検閲・海の名言）=========
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODERATION_MODEL=gpt-4o-mini

# ========= 広告枠（任意）=========
# 1 にすると枠のプレビュー UI を表示（ローカル確認用）。未設定＝本番はフックのみ。
# NEXT_PUBLIC_AD_PREVIEW=1

# ========= Cloudflare ローカルプレビュー（任意）=========
# wrangler dev / opennext preview 用。通常は production。
# NEXTJS_ENV=development
